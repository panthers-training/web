---
import './index.css';
import List from '../../../components/List/index.astro';
import Section from '../../../components/Section/index.astro';
import ListItem from '../../../components/ListItem/index.astro';
import Heading from '../../../components/Typography/Heading.astro';
import { Icon } from 'astro-icon/components';
---

<Section section="experience" containerClassName="text-xl xl:text-3xl flex flex-col gap-y-16 grow h-full" className="flex items-center py-40!">
  <Heading level="2" className="z-10 italic uppercase flex flex-col gap-y-4 text-white border-b border-b-white/10 pb-8 xl:pb-16">
    Mi perfil
  </Heading>
  <div class="flex flex-col 2xl:flex-row gap-4 xl:gap-8 xl:justify-between">

    <div class="flex flex-wrap gap-4 xl:gap-8 basis-full xl:basis-1/3 shrink-0 grow">
      <Heading level='3' className='uppercase w-full h-min'>Formación Académica</Heading>
      <div class="basis-full md:basis-1/3 shrink-0 grow border border-white/5 p-4 rounded-xl bg-black flex flex-col gap-y-2">
        <div class="border rounded-full p-2 w-min">
          <Icon name="solar:square-academic-cap-linear" class="size-6"/>
        </div>
        <p class="text-white font-serif text-lg">Lic. en Actividad Física y Deportes</p>
        <span class="text-gray-400 text-sm">UABC Mexicali.</span>
      </div>
        <div class="basis-full md:basis-1/3 shrink-0 grow border border-white/5 p-4 rounded-xl bg-black flex flex-col gap-y-2">
        <div class="border rounded-full p-2 w-min">
          <Icon name="solar:diploma-bold" class="size-6"/>
        </div>
        <p class="text-white font-serif text-lg">Maestría en Medicina Deportiva</p>
        <span class="text-gray-400 text-sm">ESNECA Business School Latinoamérica.</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-4 xl:gap-8 basis-full xl:basis-1/3 shrink-0 grow">
      <Heading level='3' className='uppercase'>Certificados</Heading>
      <List className="text-xl xl:text-2xl flex flex-wrap gap-4 items-stretch" nonBulleted listStyle="none">
        <ListItem className='flex gap-x-2 items-center text-sm border border-white/5 p-4 rounded-xl bg-black basis-full md:basis-1/3 xl:basis-1/5 shrink-0 grow cursor-pointer'>
          <Icon name="lets-icons:roll-alt-light-light" class="size-8 shrink-0 grow basis-1/6"/>
          <span class="text-white leading-relaxed line-clamp-2 xl:line-clamp-1 shrink-0 grow basis-5/6">
            Fundamentos básicos en biomecánica
          </span>
        </ListItem>
        <ListItem className='flex gap-x-2 items-center text-sm border border-white/5 p-4 rounded-xl bg-black basis-full md:basis-1/3 xl:basis-1/5 shrink-0 grow cursor-pointer'>
          <Icon name="lets-icons:roll-alt-light-light" class="size-8 shrink-0 grow basis-1/6"/>
          <span class="text-white leading-relaxed line-clamp-2 xl:line-clamp-1 shrink-0 grow basis-5/6">
            Federación nacional de Fútbol FIFA
          </span>
        </ListItem>
        <ListItem className='flex gap-x-2 items-center text-sm border border-white/5 p-4 rounded-xl bg-black basis-full md:basis-1/3 xl:basis-1/5 shrink-0 grow cursor-pointer'>
          <Icon name="lets-icons:roll-alt-light-light" class="size-8 shrink-0 grow basis-1/6"/>
          <span class="text-white leading-relaxed line-clamp-2 xl:line-clamp-1 shrink-0 grow basis-5/6">
            U.S. Center for Safe Sport
          </span>
        </ListItem>
        <ListItem className='flex gap-x-2 items-center text-sm border border-white/5 p-4 rounded-xl bg-black basis-full md:basis-1/3 xl:basis-1/5 shrink-0 grow cursor-pointer'>
          <Icon name="lets-icons:roll-alt-light-light" class="size-8 shrink-0 grow basis-1/6"/>
