---
import Heading from '../../../components/Typography/Heading.astro';
import Section from '../../../components/Section/index.astro';
import Video from '../../../components/Video/index.astro';

const BASE = import.meta.env.PUBLIC_PATH_URL ?? '';

const config = {
  loop: true,
  fluid: true,
  muted: true,
  autoplay: true,
};
---

<Section data-section="me-panthers-training">

  <!-- Typographic masthead — intentionally edge-to-edge within the page margins -->
  <div class="mb-12 xl:mb-16">
    <Heading level="2" className="z-10 italic uppercase flex flex-col gap-y-4 text-white mb-8 xl:mb-16">
      <span class="uppercase text-white">Para entrenadores</span>
    </Heading>
    <div class="flex flex-col leading-[0.9] mb-6">
      
    </div>

    <hr class="border-white/10" />

  </div>

  <!-- Body: asymmetric editorial split -->
  <div class="flex flex-col xl:flex-row gap-12 xl:gap-24">

    <!-- Left: logo + manifesto -->
    <figure class="xl:w-[38%] shrink-0 flex flex-col gap-y-12">
      <img
        src={BASE + '/panthers.training-4k-transparent-logo.png'}
        alt="Panthers Training"
        class="w-full max-w-56 xl:max-w-[18rem]"
        loading="lazy"
      />
      <figcaption class="text-white/40 italic text-base xl:text-lg leading-relaxed flex flex-col gap-y-4 xl:gap-y-8">
        <span>
          Panthers Training es el equipo de alto rendimiento que fundé para llevar su metodología a escala.
        </span>
        <span>
          Somos un equipo de profesionales en preparación física. En Panthers Training, creemos que puedes alcanzar nuevas altitudes.
        </span>
      </figcaption>
    </figure>

    <!-- Right: narrative, features, CTA -->
    <div class="flex flex-col gap-y-10 relative p-4 xl:p-8 grow shrink-0 min-h-150 justify-end">
      <Video src={import.meta.env.PUBLIC_PATH_URL + "/panthers"} class='absolute object-cover h-full w-full rounded-2xl z-0' containerClass="absolute inset-0" setup={config} inline/>
      <a
        href="https://wa.me/5216531039219?text=Hola!%20Vi%20la%20página%20y%20me%20gustaría%20%20pertenecer%20al%20equipo%20"
        class="relative z-10 bg-accent text-black font-bold text-base xl:text-lg gap-x-4 xl:gap-x-8 px-8 py-4 rounded transition-opacity duration-150 hover:opacity-90 whitespace-nowrap group self-end inline-flex items-center w-full md:w-min mb-4 xl:mb-8"
      >
        <span>Ir al siguiente nivel</span>
        <span class="transition-transform duration-200 group-hover:translate-x-1.5">&rarr;</span>
      </a>
    </div>

  </div>
</Section>
