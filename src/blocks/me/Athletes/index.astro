---
import { Icon } from 'astro-icon/components';
import Section from '../../../components/Section/index.astro';
---

<Section containerClassName="text-xl xl:text-3xl flex flex-col gap-y-16 grow h-full" className="flex items-center py-40!">
  <h2 class="italic uppercase flex flex-col gap-y-4">
    <span class="text-2xl xl:text-7xl text-white text-center">
      Algunos de los atletas que han confiado en mí
    </span>
  </h2>
  <ul class="flex items-center flex-col max-w-96 mx-auto">
    <li class="flex items-center gap-x-4 bg-white/5 p-4 text-white rounded-xl border border-white/10 text-xl">
    </li>
  </ul>
</Section>