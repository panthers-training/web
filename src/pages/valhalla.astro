---
import Layout from '../layouts/index.astro';
import ValhallaAnnounce from '../components/ValhallaAnnounce/index.astro';
import Footer from '../components/Footer/index.astro';
const BASE = import.meta.env.PUBLIC_PATH_URL ?? '';
const links = [
	{ label: 'Inicio', href: BASE + '/' },
	{ label: 'Panthers Training', href: BASE + '/panthers-training' },
	{ label: 'Contacto', href: "https://wa.me/5216531039219?text=Hola!%20Vi%20la%20página%20y%20me%20gustaría%20%20una%20evaluación", className: 'text-accent bg-black/75' },
];
---

<Layout navigationLinks={links}>
	<ValhallaAnnounce />
	<Footer />
</Layout>