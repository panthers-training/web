---
import Layout from '../layouts/index.astro';
import Hero from '../components/Hero/index.astro';
import Brief from '../blocks/me/Brief/index.astro';
import Overview from '../blocks/me/Overview/index.astro';
import Services from '../blocks/me/Services/index.astro';
import Results from '../blocks/me/Results/index.astro';
import Athletes from '../blocks/me/Athletes/index.astro';
import Experience from '../blocks/me/Experience/index.astro';
import Workflow from '../blocks/me/Workflow/index.astro';
import Institutions from '../components/Institutions/index.astro';
import Testimonials from '../components/Testimonials/index.astro';
import Footer from '../components/Footer/index.astro';

const BASE = import.meta.env.PUBLIC_PATH_URL ?? '';
const links = [
	{ label: 'Panthers Training', href: BASE + '/panthers-training' },
	{ label: 'Panthers Valhalla', href: BASE + '/valhalla' },
	{ label: 'Contacto', href: '#contact', className: 'text-accent bg-black/75' },
];
---

<Layout navigationLinks={links}>
	<Hero />
	<Brief />
	<Overview />
	<Athletes />
	<Results />
	<Experience />
	<Services />
	<Testimonials />
	<Institutions images={[
		{ src: BASE + '/institution1.jpeg', alt: 'Institution 1' },
		{ src: BASE + '/institution2.jpeg', alt: 'Institution 2' },
		{ src: BASE + '/institution3.jpeg', alt: 'Institution 3' },
		{ src: BASE + '/institution4.jpeg', alt: 'Institution 4' },
		{ src: BASE + '/institution5.jpeg', alt: 'Institution 5' },
		{ src: BASE + '/institution6.jpeg', alt: 'Institution 6' },
	]} />
	<Workflow />
	<Footer/>
</Layout>