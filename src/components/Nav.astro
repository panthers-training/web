---
import { Icon } from 'astro-icon/components';
import List from './List/index.astro';
import ListItem from './ListItem/index.astro';

interface Props {
	navigationLinks?: Array<{ label: string; href: string; hidden?: boolean; className?: string; }>;
}
const homePathname = `${import.meta.env.PUBLIC_PATH_URL}/`;
const isHomePage = Astro.url.pathname === homePathname;
const { navigationLinks = [] } = Astro.props;
---

<nav id="main-nav" class={`nav-container bg-black/80 fixed top-0 left-0 right-0 z-50 transition-all duration-300 h-20 flex items-center justify-between px-8 xl:px-32`}>
	<a id="nav-logo" href={import.meta.env.PUBLIC_PATH_URL + "/"} class={`transition-opacity duration-300 ${isHomePage ? 'opacity-0 pointer-events-none' : ''}`}>
		<img class="h-10" src={import.meta.env.PUBLIC_PATH_URL + "/logo.png"} alt="Panthers Training Logo"/>
	</a>

	<!-- Desktop nav links (lg+) -->
	<div class="text-white py-4 hidden lg:flex justify-between">
		<div class="gap-8">
			<List className="flex items-center gap-x-2" listStyle='none'>
				{
					navigationLinks.map((link) => (
						<ListItem>
							<a
								href={link.href}
								class={`nav-link relative p-4 text-sm font-medium text-white transition-colors duration-200 rounded-full hover:text-accent ${link.className ?? ''}`}
							>
								{link.label}
							<span class="nav-link-underline absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-accent to-accent scale-x-0 transition-transform duration-300"></span>
							</a>
						</ListItem>
					))
				}
			</List>
		</div>
	</div>

	<!-- Mobile hamburger button (below lg) -->
	<button id="mobile-menu-toggle" class="flex lg:hidden text-white p-2 cursor-pointer" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
		<Icon name="solar:hamburger-menu-outline" class="size-8" />
	</button>
</nav>

<!-- Mobile fullscreen menu (below lg) -->
<div
	id="mobile-menu"
	class="fixed inset-0 bg-black z-60 flex flex-col items-center justify-center lg:hidden translate-x-full transition-transform duration-300 ease-in-out"
	aria-hidden="true"
>
	<button id="mobile-menu-close" class="absolute top-6 right-8 text-white p-2 cursor-pointer" aria-label="Close menu">
		<Icon name="solar:close-circle-bold" class="size-8" />
	</button>

	<List className="flex flex-col items-center gap-y-10">
		{
			navigationLinks.map((link) => (
				<ListItem>
					<a
						href={link.href}
						class={`mobile-nav-link text-white text-2xl font-medium hover:text-accent transition-colors duration-200 ${link.className ?? ''}`}
					>
						{link.label}
					</a>
				</ListItem>
			))
		}
	</List>
</div>

<script define:vars={{ isHomePage }}>
	const nav = document.getElementById('main-nav');
	const logo = document.getElementById('nav-logo');
	const mobileMenu = document.getElementById('mobile-menu');
	const toggleBtn = document.getElementById('mobile-menu-toggle');
	const closeBtn = document.getElementById('mobile-menu-close');

	function openMenu() {
		mobileMenu?.classList.remove('translate-x-full');
		mobileMenu?.setAttribute('aria-hidden', 'false');
		toggleBtn?.setAttribute('aria-expanded', 'true');
		document.body.classList.add('overflow-hidden');
	}

	function closeMenu() {
		mobileMenu?.classList.add('translate-x-full');
		mobileMenu?.setAttribute('aria-hidden', 'true');
		toggleBtn?.setAttribute('aria-expanded', 'false');
		document.body.classList.remove('overflow-hidden');
	}

	toggleBtn?.addEventListener('click', openMenu);
	closeBtn?.addEventListener('click', closeMenu);

	// Close menu when a nav link is clicked
	mobileMenu?.querySelectorAll('.mobile-nav-link').forEach((link) => {
		link.addEventListener('click', closeMenu);
	});

	function handleScroll() {
		const scrolled = window.scrollY > 0;

		if (scrolled) {
			nav?.classList.add('scrolled');
		} else {
			nav?.classList.remove('scrolled');
		}

		if (isHomePage && logo) {
			if (scrolled) {
				logo.classList.remove('opacity-0', 'pointer-events-none');
			} else {
				logo.classList.add('opacity-0', 'pointer-events-none');
			}
		}
	}

	// Initial check
	handleScroll();

	// Listen for scroll events
	window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style>
	.nav-container {
		background-color: transparent;
		border-bottom: 0.5px solid transparent;
	}

	.nav-container.scrolled {
		background-color: rgba(0, 0, 0, 0.8);
		border-bottom-color: var(--color-accent);
	}

	@media (width >= 1024px) {
		.nav-link:hover .nav-link-underline {
			scale: 1;
		}
	}

	/* Smooth scroll behavior for anchor links */
	:global(html) {
		scroll-behavior: smooth;
	}
</style>
