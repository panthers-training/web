---
interface Props {
	navigationLinks?: Array<{ label: string; href: string; hidden?: boolean; className?: string; }>;
}
const isHomePage = Astro.url.pathname === '/';
const { navigationLinks = [] } = Astro.props;
---

<nav id="main-nav" class={`nav-container bg-black/80 fixed top-0 left-0 right-0 z-50 transition-all duration-300 h-20 flex items-center justify-between px-8 xl:px-32`}>
	<a id="nav-logo" href={import.meta.env.PUBLIC_PATH_URL + "/"} class={`transition-opacity duration-300 ${isHomePage ? 'opacity-0 pointer-events-none' : ''}`}>
		<img class="h-10" src={import.meta.env.PUBLIC_PATH_URL + "/logo.png"} alt="Panthers Training Logo"/>
	</a>
	<div class="text-white py-4 flex justify-between">
		<!-- Navigation Links -->
		<div class="gap-8">
			<ul class="flex items-center gap-x-2">
				{
					navigationLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class={`nav-link relative p-4 text-sm font-medium text-white transition-colors duration-200 rounded-full hover:text-accent ${link.className ?? ''}`}
							>
								{link.label}
							<span class="nav-link-underline absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-accent to-accent scale-x-0 transition-transform duration-300"></span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</nav>

<script define:vars={{ isHomePage }}>
	const nav = document.getElementById('main-nav');
	const logo = document.getElementById('nav-logo');

	function handleScroll() {
		const scrolled = window.scrollY > 0;

		if (scrolled) {
			nav?.classList.add('scrolled');
		} else {
			nav?.classList.remove('scrolled');
		}

		if (isHomePage && logo) {
			if (scrolled) {
				logo.classList.remove('opacity-0', 'pointer-events-none');
			} else {
				logo.classList.add('opacity-0', 'pointer-events-none');
			}
		}
	}

	// Initial check
	handleScroll();

	// Listen for scroll events
	window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style>
	.nav-container {
		background-color: transparent;
		border-bottom: 0.5px solid transparent;
	}

	.nav-container.scrolled {
		background-color: rgba(0, 0, 0, 0.8);
		border-bottom-color: var(--color-accent);
	}


	@media (width >= 1024px) {
		.nav-link:hover .nav-link-underline {
			scale: 1;
		}
	}

	/* Smooth scroll behavior for anchor links */
	:global(html) {
		scroll-behavior: smooth;
	}
</style>