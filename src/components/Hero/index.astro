---
import './index.css';
import Video from '../Video/index.astro';

const config = {
  loop: true,
  fluid: true,
  muted: true,
  autoplay: true,
};
---

<section data-section="hero" class="h-dvh relative">
  <Video src={import.meta.env.PUBLIC_PATH_URL + "/hero.webm"} class='absolute object-cover h-full w-full' containerClass="absolute inset-0" setup={config}/>
  <div class="flex flex-col justify-between max-w-360 px-8 h-full py-16 mx-auto relative z-10">
    <figure class="flex flex-col max-w-150 text-end" data-section="hero-logo">
      <img class="max-h-full max-w-full" src={import.meta.env.PUBLIC_PATH_URL + "/logo.png"}/>
      <figcaption class="text-2xl mt-2 flex flex-col text-white">
        <span>Entrenador profesional</span>
        <span>y preparador físico de alto rendimiento</span>
      </figcaption>
    </figure>
    <h2 class="text-xl xl:text-3xl flex flex-col text-end pb-32">
      <span>
        Optimización del rendimiento.
      </span>
      <span class="text-white">
        Transformación física.
      </span>
      <span>
        Rehabilitación integral basada en ciencia.
      </span>
      <span class="text-white">
        Experiencia real.
      </span>
    </h2>
  </div>
</section>