<section class="p-8 md:p-32 flex flex-col gap-y-4 md:gap-y-0">
  <h2 class="text-2xl md:text-3xl">¿Qué es Panthers Training?</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 md:gap-y-8">
    <div class="hidden md:flex flex-col h-full justify-center">
      <p data-slide-index="0" class="text-white text-xl xl:text-3xl md:min-h-dvh flex items-center">
        Somos un equipo de profesionales en preparación física. En Panthers Training, creemos que puedes alcanzar nuevas altitudes.
      </p>
      <p data-slide-index="1" class="text-white text-xl xl:text-3xl md:min-h-dvh flex items-center">
        Nuestro desempeño se basa en la ciencia del deporte, la experiencia y la pasión por ayudar a nuestros clientes a alcanzar sus objetivos.
      </p>
      <p data-slide-index="2" class="text-white text-xl xl:text-3xl md:min-h-dvh flex items-center">
        Ofrecemos planes personalizados de entrenamiento, asesoramiento nutricional y apoyo continuo para garantizar que cada persona pueda lograr su mejor versión física.
      </p>
      <p data-slide-index="3" class="text-accent text-2xl xl:text-3xl md:min-h-dvh flex items-center">Y queremos estar ahí para ello.</p>
    </div>
    <figure class="flex md:sticky flex-col relative items-center md:top-0 md:h-dvh justify-center">
        <img
          id="about-image"
          alt="Panthers Training"
          src=""
          class="object-contain rounded-md overflow-hidden w-full h-full relative z-10 opacity-10 md:opacity-100"
          style="transition: opacity 0.3s ease;"
        />
        <figcaption class="absolute top-0 z-10 h-full flex flex-col gap-y-8 md:hidden">
          <p class="text-white text-md md:text-2xl">
                Somos un equipo de profesionales en preparación física. En Panthers Training, creemos que puedes alcanzar nuevas altitudes.
          </p>
          <p class="text-white text-md md:text-2xl">
            Nuestro desempeño se basa en la ciencia del deporte, la experiencia y la pasión por ayudar a nuestros clientes a alcanzar sus objetivos.
          </p>
          <p class="text-white text-md md:text-2xl">
            Ofrecemos planes personalizados de entrenamiento, asesoramiento nutricional y apoyo continuo para garantizar que cada persona pueda lograr su mejor versión física.
          </p>
          <p class="text-accent text-md md:text-2xl">Y queremos estar ahí para ello.</p>
        </figcaption>
    </figure>
  </div>
</section>

<script>
  const BASE = import.meta.env.PUBLIC_PATH_URL ?? '';
  const slides = [
    BASE + '/about_1.jpg',
    BASE + '/about_2.jpg',
    BASE + '/about_3.jpg',
    BASE + '/about_4.jpg',
  ];
  let currentSlide = 0;
  let observer: IntersectionObserver | null = null;
  const MD = window.matchMedia('(min-width: 768px)');
  const img = document.getElementById('about-image') as HTMLImageElement | null;

  if (img) img.src = slides[currentSlide];
  function initObserver() {
    if (!MD.matches) return;

    
    const paragraphs = document.querySelectorAll<HTMLElement>('[data-slide-index]');

    if (!img || paragraphs.length === 0) return;

    // rootMargin shrinks the observable viewport to a horizontal band in the
    // centre (~20% of the viewport height). Each min-h-dvh paragraph fires
    // when it crosses that band, giving one trigger per paragraph as the user
    // scrolls through.
    observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const index = parseInt((entry.target as HTMLElement).dataset.slideIndex ?? '0', 10);
          if (index === currentSlide) continue;
          currentSlide = index;
          img.style.opacity = '0';
          setTimeout(() => {
            img.src = slides[index];
            img.style.opacity = '1';
          }, 150);
        }
      },
      { rootMargin: '-40% 0px -40% 0px', threshold: 0 },
    );

    paragraphs.forEach((p) => observer!.observe(p));
  }

  // initObserver();

  // Re-initialise if the user resizes into md territory.
